DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-server-ip
DJANGO_CSRF_TRUSTED_ORIGINS=http://your-server-ip,https://your-domain.com
DJANGO_TIME_ZONE=UTC

USE_POSTGRES=1
POSTGRES_DB=photo_app
POSTGRES_USER=photo_app
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DJANGO_MEDIA_ROOT=/app/media
DJANGO_STATIC_ROOT=/app/staticfiles

LLAVA_ENDPOINT_URL=http://llava:8001/analyze
LLAVA_TIMEOUT_SECONDS=180
LLAVA_GENERATION_TIMEOUT_SECONDS=180
LLAVA_AUTH_TOKEN=
LLAVA_MODEL_ID=llava-hf/llava-1.5-7b-hf
LLAVA_LOAD_IN_4BIT=1
LLAVA_MAX_NEW_TOKENS=256
TRANSLATE_TO_RUSSIAN=1

FACE_DETECTION_ENABLED=1
FACE_ANALYSIS_MODEL_NAME=buffalo_l
FACE_ANALYSIS_PROVIDERS=CPUExecutionProvider
FACE_ANALYSIS_DET_WIDTH=640
FACE_ANALYSIS_DET_HEIGHT=640
FACE_MIN_SIZE_PX=48
FACE_MIN_AREA_RATIO=0.0025

DJANGO_GUNICORN_WORKERS=3
DJANGO_GUNICORN_TIMEOUT=120
DRF_PAGE_SIZE=50
NGINX_PORT=80
